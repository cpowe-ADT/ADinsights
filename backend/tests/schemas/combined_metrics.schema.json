{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Combined Metrics Payload",
  "type": "object",
  "required": ["campaign", "creative", "budget", "parish", "snapshot_generated_at"],
  "properties": {
    "tenant_id": { "type": "string" },
    "tenant_label": { "type": "string" },
    "snapshot_generated_at": { "type": "string" },
    "campaign": {
      "type": "object",
      "required": ["summary", "trend", "rows"],
      "properties": {
        "summary": {
          "type": "object",
          "required": [
            "currency",
            "totalSpend",
            "totalImpressions",
            "totalClicks",
            "totalConversions",
            "averageRoas"
          ],
          "properties": {
            "currency": { "type": "string" },
            "totalSpend": { "type": "number" },
            "totalImpressions": { "type": "number" },
            "totalClicks": { "type": "number" },
            "totalConversions": { "type": "number" },
            "averageRoas": { "type": "number" }
          },
          "additionalProperties": false
        },
        "trend": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "spend", "conversions", "clicks", "impressions"],
            "properties": {
              "date": { "type": "string" },
              "spend": { "type": "number" },
              "conversions": { "type": "number" },
              "clicks": { "type": "number" },
              "impressions": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "platform",
              "status",
              "parishes",
              "spend",
              "impressions",
              "clicks",
              "conversions",
              "roas"
            ],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "platform": { "type": "string" },
              "status": { "type": "string" },
              "objective": { "type": "string" },
              "parishes": { "type": "array", "items": { "type": "string" } },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "roas": { "type": "number" },
              "ctr": { "type": "number" },
              "cpc": { "type": "number" },
              "cpm": { "type": "number" },
              "startDate": { "type": "string" },
              "endDate": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "creative": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "campaignId",
          "campaignName",
          "platform",
          "spend",
          "impressions",
          "clicks",
          "conversions",
          "roas"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "campaignId": { "type": "string" },
          "campaignName": { "type": "string" },
          "platform": { "type": "string" },
          "parishes": { "type": "array", "items": { "type": "string" } },
          "spend": { "type": "number" },
          "impressions": { "type": "number" },
          "clicks": { "type": "number" },
          "conversions": { "type": "number" },
          "roas": { "type": "number" },
          "ctr": { "type": "number" },
          "thumbnailUrl": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "budget": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "campaignName",
          "parishes",
          "monthlyBudget",
          "spendToDate",
          "projectedSpend",
          "pacingPercent",
          "startDate",
          "endDate"
        ],
        "properties": {
          "id": { "type": "string" },
          "campaignName": { "type": "string" },
          "parishes": { "type": "array", "items": { "type": "string" } },
          "monthlyBudget": { "type": "number" },
          "spendToDate": { "type": "number" },
          "projectedSpend": { "type": "number" },
          "pacingPercent": { "type": "number" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "parish": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["parish", "spend", "impressions", "clicks", "conversions"],
        "properties": {
          "parish": { "type": "string" },
          "spend": { "type": "number" },
          "impressions": { "type": "number" },
          "clicks": { "type": "number" },
          "conversions": { "type": "number" },
          "roas": { "type": "number" },
          "campaignCount": { "type": "number" },
          "currency": { "type": "string" },
          "campaigns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "coverage": {
      "type": "object",
      "properties": {
        "startDate": { "type": ["string", "null"] },
        "endDate": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "availability": {
      "type": "object",
      "properties": {
        "campaign": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "reason": { "type": ["string", "null"] }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "creative": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "reason": { "type": ["string", "null"] }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "budget": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "reason": { "type": ["string", "null"] }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "parish_map": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "reason": { "type": ["string", "null"] },
            "coverage_percent": { "type": "number" }
          },
          "required": ["status"],
          "additionalProperties": false
        }
      },
      "required": ["campaign", "creative", "budget", "parish_map"],
      "additionalProperties": false
    },
    "demographics": {
      "type": "object",
      "properties": {
        "byAge": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ageRange", "spend", "impressions", "clicks", "conversions", "reach"],
            "properties": {
              "ageRange": { "type": "string" },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "reach": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "byGender": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gender", "spend", "impressions", "clicks", "conversions", "reach"],
            "properties": {
              "gender": { "type": "string" },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "reach": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "byAgeGender": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ageRange", "gender", "spend", "impressions", "clicks", "conversions", "reach"],
            "properties": {
              "ageRange": { "type": "string" },
              "gender": { "type": "string" },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "reach": { "type": "number" }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["byAge", "byGender", "byAgeGender"],
      "additionalProperties": false
    },
    "platforms": {
      "type": "object",
      "properties": {
        "byPlatform": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["platform", "spend", "impressions", "clicks", "conversions", "reach"],
            "properties": {
              "platform": { "type": "string" },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "reach": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "byDevice": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["device", "spend", "impressions", "clicks", "conversions", "reach"],
            "properties": {
              "device": { "type": "string" },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "reach": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "byPlatformDevice": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["platform", "device", "spend", "impressions", "clicks", "conversions", "reach"],
            "properties": {
              "platform": { "type": "string" },
              "device": { "type": "string" },
              "spend": { "type": "number" },
              "impressions": { "type": "number" },
              "clicks": { "type": "number" },
              "conversions": { "type": "number" },
              "reach": { "type": "number" }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["byPlatform", "byDevice", "byPlatformDevice"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
