{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adinsights.dev/schemas/creative.schema.json",
  "title": "CreativePerformanceRows",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "campaignId",
      "campaignName",
      "platform",
      "spend",
      "impressions",
      "clicks",
      "conversions",
      "roas"
    ],
    "properties": {
      "id": { "type": "string" },
      "adAccountId": { "type": "string" },
      "name": { "type": "string" },
      "campaignId": { "type": "string" },
      "campaignName": { "type": "string" },
      "platform": { "type": "string" },
      "parishes": {
        "type": "array",
        "items": { "type": "string" }
      },
      "spend": { "type": "number" },
      "impressions": { "type": "number" },
      "reach": { "type": "number" },
      "clicks": { "type": "number" },
      "conversions": { "type": "number" },
      "roas": { "type": "number" },
      "ctr": { "type": "number" },
      "cpc": { "type": "number" },
      "cpm": { "type": "number" },
      "cpa": { "type": "number" },
      "frequency": { "type": "number" },
      "startDate": { "type": "string", "format": "date" },
      "endDate": { "type": "string", "format": "date" },
      "thumbnailUrl": {
        "type": "string",
        "anyOf": [
          { "format": "uri" },
          { "pattern": "^/" }
        ]
      }
    }
  }
}
